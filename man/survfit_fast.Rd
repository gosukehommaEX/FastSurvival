  \item \code{"log"}: Interval on the log scale (default in
    \code{\link[survival]{survfit}}),
    S(t) * exp(+/- z * SE / S(t)).
  \item \code{"log-log"}: Interval on the complementary log-log scale,
    S(t)^exp(+/- z * SE / (S(t) * log(S(t)))).
